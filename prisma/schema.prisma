generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id
  name      String
  category  String
  price     Float
  unit      String
  weight    String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  isBusiness   Boolean  @default(false)
  company      String   @default("")
  cui          String   @default("")
  phone        String   @default("")
  county       String   @default("")
  city         String   @default("")
  address      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id        String      @id
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  status    String      @default("Noua")
  company   String
  cui       String      @default("")
  contact   String
  phone     String
  email     String
  county    String
  city      String      @default("")
  address   String      @default("")
  notes     String      @default("")
  total     Float
  weight    Float
  items     OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  category  String
  price     Float
  unit      String
  weight    String?
  qty       Int
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
